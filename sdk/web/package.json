{
    "name": "@loxi/worker-device",
    "version": "0.1.0",
    "description": "Universal Worker SDK for Loxi Protocol — matches the LoxiWorkerDevice class",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "files": [
