# Rust
target/
Cargo.lock
**/*.rs.bk
*.pdb

# Loxi Artifacts & Distribution (SINGLE SOURCE OF TRUTH)
# We ignore the dist/public folder entirely as it is generated by build_artifacts.sh
protocol/crates/logistics/loxi-logistics/public/

# Valhalla Engine (C++ Logic)
# Track the SOURCE and the OFFICIAL BINARY (to avoid requiring Emscripten for all)
# But ignore intermediate build artifacts
protocol/crates/logistics/loxi-matrix/engine/src/*.o
protocol/crates/logistics/loxi-matrix/engine/src/*.a
protocol/crates/logistics/loxi-matrix/engine/src/*.so
protocol/crates/logistics/loxi-matrix/engine/compile_log.txt

# Explicitly TRACK the official engine binaries in the engine source
!protocol/crates/logistics/loxi-matrix/engine/src/valhalla_engine.js
!protocol/crates/logistics/loxi-matrix/engine/src/valhalla_engine.wasm
!protocol/crates/logistics/loxi-matrix/engine/src/ValhallaResourceManager.js

