protocol/crates/logistics/loxi-logistics/data/valhalla_tiles/*.pbf
protocol/crates/logistics/loxi-logistics/data/valhalla_tiles/*.osm
!protocol/crates/logistics/loxi-logistics/data/valhalla_tiles/valhalla.json

