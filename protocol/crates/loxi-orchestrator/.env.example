# Loxi Orchestrator — Environment Variables
# Copy this file to .env and fill in your own values.
#
# Generate a fresh RSA keypair with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#
# Then encode as single-line with \n separators:
#   awk 'NF{printf "%s\\n", $0}' private.pem

RSA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<your_base64_key_here>\n-----END PRIVATE KEY-----"
RSA_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n<your_base64_key_here>\n-----END PUBLIC KEY-----"
